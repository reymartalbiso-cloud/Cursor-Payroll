# Database (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_NAME="Payroll System"
NEXT_PUBLIC_COMPANY_NAME="Your Company Name"
NEXT_PUBLIC_COMPANY_ADDRESS="123 Business Street, City, Country"
NEXT_PUBLIC_COMPANY_PHONE="+63 123 456 7890"
NEXT_PUBLIC_COMPANY_EMAIL="payroll@company.com"

# Settings
NEXT_PUBLIC_CURRENCY="PHP"
NEXT_PUBLIC_STANDARD_DAILY_HOURS="8"
NEXT_PUBLIC_OVERTIME_MULTIPLIER="1.25"

# LifeScan Accounting Edge Function (Supabase)
# Base URL: https://[project-id].supabase.co/functions/v1/accounting
# Uses Bearer token auth. Set LIFESCAN_API_KEY to match Supabase secret LIFESCAN_API_KEY.
LIFESCAN_API_URL="https://[project-id].supabase.co/functions/v1/accounting"
LIFESCAN_API_KEY="ls_sk_xxxx"   # Or value from Supabase secrets
