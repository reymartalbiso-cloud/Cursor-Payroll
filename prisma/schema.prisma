generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String
  name       String
  role       UserRole   @default(PAYROLL_ADMIN)
  employeeId String?    @unique
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  auditLogs  AuditLog[]
  employee   Employee?  @relation(fields: [employeeId], references: [id])

  @@map("users")
}

model Employee {
  id                     String           @id @default(cuid())
  employeeNo             String           @unique
  firstName              String
  lastName               String
  middleName             String?
  department             String
  position               String
  rateType               RateType         @default(DAILY)
  dailyRate              Decimal          @db.Decimal(12, 4)
  basicPayPerCutoff      Decimal?         @db.Decimal(12, 2)
  defaultKpi             Decimal          @default(0) @db.Decimal(12, 2)
  sssContribution        Decimal          @default(0) @db.Decimal(12, 2)
  philhealthContribution Decimal          @default(0) @db.Decimal(12, 2)
  pagibigContribution    Decimal          @default(0) @db.Decimal(12, 2)
  sssLoan                Decimal          @default(0) @db.Decimal(12, 2)
  pagibigLoan            Decimal          @default(0) @db.Decimal(12, 2)
  otherLoans             Decimal          @default(0) @db.Decimal(12, 2)
  cashAdvance            Decimal          @default(0) @db.Decimal(12, 2)
  status                 EmployeeStatus   @default(ACTIVE)
  startDate              DateTime?
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  monthlySalary          Decimal          @default(0) @db.Decimal(12, 2)
  payslips               Payslip[]
  timesheetEntries       TimesheetEntry[]
  user                   User?

  @@map("employees")
}

model PayrollRun {
  id                 String           @id @default(cuid())
  name               String
  cutoffType         CutoffType
  cutoffStart        DateTime
  cutoffEnd          DateTime
  payDate            DateTime
  year               Int
  month              Int
  eligibleWorkdays   Int
  status             PayrollStatus    @default(DRAFT)
  notes              String?
  govDeductionMode   String           @default("fixed_per_cutoff")
  standardDailyHours Int              @default(8)
  overtimeMultiplier Decimal          @default(1.25) @db.Decimal(4, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  finalizedAt        DateTime?
  finalizedBy        String?
  auditLogs          AuditLog[]
  importHistory      ImportHistory[]
  payslips           Payslip[]
  timesheetEntries   TimesheetEntry[]

  @@unique([year, month, cutoffType])
  @@map("payroll_runs")
}

model TimesheetEntry {
  id                       String     @id @default(cuid())
  payrollRunId             String
  employeeId               String
  date                     DateTime
  timeIn                   String?
  timeOut                  String?
  hoursWorked              Decimal?   @db.Decimal(10, 5)
  minutesLate              Int        @default(0)
  undertimeMinutes         Int        @default(0)
  isAbsent                 Boolean    @default(false)
  overtimeHours            Decimal    @default(0) @db.Decimal(10, 5)
  holidayPay               Decimal    @default(0) @db.Decimal(12, 2)
  isHoliday                Boolean    @default(false)
  holidayType              String?
  remarks                  String?
  rawData                  Json?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  isOnLeave                Boolean    @default(false)
  leaveType                String?
  adjustedAt               DateTime?
  adjustedBy               String?
  adjustedLateMinutes      Int?
  adjustedOvertimeHours    Decimal?   @db.Decimal(10, 5)
  adjustedUndertimeMinutes Int?
  adjustmentRemarks        String?
  isAbsentExcused          Boolean    @default(false)
  isLateExcused            Boolean    @default(false)
  employee                 Employee   @relation(fields: [employeeId], references: [id])
  payrollRun               PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId, date])
  @@map("timesheet_entries")
}

model Payslip {
  id                    String             @id @default(cuid())
  referenceNo           String             @unique
  payrollRunId          String
  employeeId            String
  employeeName          String
  employeeNo            String
  department            String
  position              String
  dailyRate             Decimal            @db.Decimal(12, 2)
  eligibleWorkdays      Int
  presentDays           Int
  absentDays            Int
  totalLateMinutes      Int                @default(0)
  totalUndertimeMinutes Int                @default(0)
  totalOvertimeHours    Decimal            @default(0) @db.Decimal(10, 5)
  basicPay              Decimal            @db.Decimal(12, 2)
  overtimePay           Decimal            @default(0) @db.Decimal(12, 2)
  holidayPay            Decimal            @default(0) @db.Decimal(12, 2)
  cola                  Decimal            @default(0) @db.Decimal(12, 2)
  kpi                   Decimal            @default(0) @db.Decimal(12, 2)
  otherEarnings         Decimal            @default(0) @db.Decimal(12, 2)
  grossPay              Decimal            @db.Decimal(12, 2)
  absenceDeduction      Decimal            @default(0) @db.Decimal(12, 2)
  lateDeduction         Decimal            @default(0) @db.Decimal(12, 2)
  undertimeDeduction    Decimal            @default(0) @db.Decimal(12, 2)
  sssDeduction          Decimal            @default(0) @db.Decimal(12, 2)
  philhealthDeduction   Decimal            @default(0) @db.Decimal(12, 2)
  pagibigDeduction      Decimal            @default(0) @db.Decimal(12, 2)
  sssLoanDeduction      Decimal            @default(0) @db.Decimal(12, 2)
  pagibigLoanDeduction  Decimal            @default(0) @db.Decimal(12, 2)
  otherLoanDeduction    Decimal            @default(0) @db.Decimal(12, 2)
  cashAdvanceDeduction  Decimal            @default(0) @db.Decimal(12, 2)
  thirteenthMonthAdj    Decimal            @default(0) @db.Decimal(12, 2)
  otherDeductions       Decimal            @default(0) @db.Decimal(12, 2)
  totalDeductions       Decimal            @db.Decimal(12, 2)
  netPay                Decimal            @db.Decimal(12, 2)
  netPayInWords         String?
  govDeductionsApplied  Boolean            @default(false)
  computationBreakdown  Json?
  isMissing             Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  absentCount           Int                @default(0)
  kpiVoidReason         String?
  kpiVoided             Boolean            @default(false)
  lateCount             Int                @default(0)
  monthlyAbsentCount    Int                @default(0)
  monthlyLateCount      Int                @default(0)
  deductions            PayslipDeduction[]
  earnings              PayslipEarning[]
  employee              Employee           @relation(fields: [employeeId], references: [id])
  payrollRun            PayrollRun         @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

model PayslipEarning {
  id          String  @id @default(cuid())
  payslipId   String
  type        String
  description String
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)
  payslip     Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@map("payslip_earnings")
}

model PayslipDeduction {
  id          String  @id @default(cuid())
  payslipId   String
  type        String
  description String
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)
  payslip     Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@map("payslip_deductions")
}

model ImportHistory {
  id                    String     @id @default(cuid())
  payrollRunId          String
  fileName              String
  fileData              Bytes?
  sheetName             String?
  columnMapping         Json
  totalRows             Int
  successRows           Int
  errorRows             Int
  missingEmployees      Json?
  unrecognizedEmployees Json?
  importedBy            String
  importedAt            DateTime   @default(now())
  payrollRun            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@map("import_history")
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String
  payrollRunId String?
  action       String
  entityType   String
  entityId     String
  oldValue     Json?
  newValue     Json?
  description  String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())
  payrollRun   PayrollRun? @relation(fields: [payrollRunId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([payrollRunId])
  @@map("audit_logs")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model OutsourceProject {
  id              String                    @id @default(cuid())
  name            String
  rate            Decimal                   @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  paymentBasis    String                    @default("EFFECTIVE_HOUR")
  payrollRequests OutsourcePayrollRequest[]

  @@map("outsource_projects")
}

model OutsourcePayrollRequest {
  id          String                   @id @default(cuid())
  projectId   String
  requestName String
  periodStart DateTime?                @db.Date
  periodEnd   DateTime?                @db.Date
  totalAmount Decimal                  @default(0) @db.Decimal(12, 2)
  status      String                   @default("DRAFT")
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  entries     OutsourceOperatorEntry[]
  project     OutsourceProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("outsource_payroll_requests")
}

model OutsourceOperatorEntry {
  id            String                  @id @default(cuid())
  requestId     String
  operatorName  String
  output        Decimal                 @db.Decimal(12, 4)
  calculatedPay Decimal                 @db.Decimal(12, 2)
  remarks       String?
  createdAt     DateTime                @default(now())
  request       OutsourcePayrollRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("outsource_operator_entries")
}

model Holiday {
  id          String      @id @default(cuid())
  name        String
  date        DateTime    @unique @db.Date
  type        HolidayType
  year        Int
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([year])
  @@map("holidays")
}

enum UserRole {
  ADMIN
  PAYROLL_ADMIN
  EMPLOYEE_VIEWER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum RateType {
  DAILY
  MONTHLY
}

enum CutoffType {
  FIRST_HALF
  SECOND_HALF
}

enum PayrollStatus {
  DRAFT
  REVIEWED
  FINALIZED
}

enum HolidayType {
  REGULAR
  SPECIAL
}
