// Prisma Schema for Payroll System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== USERS & AUTH ====================

enum UserRole {
  ADMIN
  PAYROLL_ADMIN
  EMPLOYEE_VIEWER  // Deprecated - kept for database compatibility
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  name         String
  role         UserRole  @default(PAYROLL_ADMIN)
  employeeId   String?   @unique  // Deprecated - kept for database compatibility
  employee     Employee? @relation(fields: [employeeId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  auditLogs    AuditLog[]
  
  @@map("users")
}

// ==================== EMPLOYEES ====================

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum RateType {
  DAILY
  MONTHLY
}

model Employee {
  id              String         @id @default(cuid())
  employeeNo      String         @unique
  firstName       String
  lastName        String
  middleName      String?
  department      String
  position        String
  rateType        RateType       @default(DAILY)
  // Monthly Salary is the source of truth for payroll calculations
  // Daily Rate is auto-calculated as: monthlySalary / 26
  monthlySalary   Decimal        @default(0) @db.Decimal(12, 2)
  dailyRate       Decimal        @db.Decimal(12, 4)  // Stored with 4 decimals for precision display
  basicPayPerCutoff Decimal?     @db.Decimal(12, 2)
  defaultKpi      Decimal        @default(0) @db.Decimal(12, 2)
  
  // Government contribution defaults
  sssContribution      Decimal  @default(0) @db.Decimal(12, 2)
  philhealthContribution Decimal @default(0) @db.Decimal(12, 2)
  pagibigContribution  Decimal  @default(0) @db.Decimal(12, 2)
  
  // Loans and deductions
  sssLoan         Decimal        @default(0) @db.Decimal(12, 2)
  pagibigLoan     Decimal        @default(0) @db.Decimal(12, 2)
  otherLoans      Decimal        @default(0) @db.Decimal(12, 2)
  cashAdvance     Decimal        @default(0) @db.Decimal(12, 2)
  
  status          EmployeeStatus @default(ACTIVE)
  startDate       DateTime?
  notes           String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  
  user            User?
  timesheetEntries TimesheetEntry[]
  payslips        Payslip[]
  
  @@map("employees")
}

// ==================== PAYROLL RUNS ====================

enum CutoffType {
  FIRST_HALF    // 1-15
  SECOND_HALF   // 16-end of month
}

enum PayrollStatus {
  DRAFT
  REVIEWED
  FINALIZED
}

model PayrollRun {
  id              String        @id @default(cuid())
  name            String
  cutoffType      CutoffType
  cutoffStart     DateTime
  cutoffEnd       DateTime
  payDate         DateTime
  year            Int
  month           Int
  
  eligibleWorkdays Int          // Calculated: Mon-Sat excluding Sundays
  
  status          PayrollStatus @default(DRAFT)
  notes           String?
  
  // Settings snapshot at time of creation
  govDeductionMode   String     @default("fixed_per_cutoff")
  standardDailyHours Int        @default(8)
  overtimeMultiplier Decimal    @default(1.25) @db.Decimal(4, 2)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  finalizedAt     DateTime?
  finalizedBy     String?
  
  timesheetEntries TimesheetEntry[]
  payslips         Payslip[]
  importHistory    ImportHistory[]
  auditLogs        AuditLog[]
  
  @@unique([year, month, cutoffType])
  @@map("payroll_runs")
}

// ==================== TIMESHEET ENTRIES ====================

model TimesheetEntry {
  id              String      @id @default(cuid())
  payrollRunId    String
  payrollRun      PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  
  date            DateTime
  timeIn          String?
  timeOut         String?
  hoursWorked     Decimal?    @db.Decimal(10, 5)
  minutesLate     Int         @default(0)
  undertimeMinutes Int        @default(0)
  isAbsent        Boolean     @default(false)
  isOnLeave       Boolean     @default(false)   // VL or SL - paid leave
  leaveType       String?     // 'VL' (Vacation Leave) or 'SL' (Sick Leave)
  overtimeHours   Decimal     @default(0) @db.Decimal(10, 5)
  holidayPay      Decimal     @default(0) @db.Decimal(12, 2)
  isHoliday       Boolean     @default(false)
  holidayType     String?     // regular, special
  
  // Manual adjustment fields - allows admin to override calculated values
  isLateExcused       Boolean   @default(false)  // If true, late won't count for KPI voiding
  isAbsentExcused     Boolean   @default(false)  // If true, absent won't count for KPI voiding
  adjustedLateMinutes Int?      // Override calculated late minutes (null = use calculated)
  adjustedUndertimeMinutes Int? // Override calculated undertime (null = use calculated)
  adjustedOvertimeHours Decimal? @db.Decimal(10, 5) // Override calculated OT (null = use calculated)
  adjustmentRemarks   String?   // Notes for adjustments (e.g., "Approved by Manager")
  adjustedBy          String?   // User who made the adjustment
  adjustedAt          DateTime? // When adjustment was made
  
  remarks         String?
  rawData         Json?       // Original imported data
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([payrollRunId, employeeId, date])
  @@map("timesheet_entries")
}

// ==================== PAYSLIPS ====================

model Payslip {
  id              String      @id @default(cuid())
  referenceNo     String      @unique
  payrollRunId    String
  payrollRun      PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  
  // Snapshot of employee data at time of payroll
  employeeName    String
  employeeNo      String
  department      String
  position        String
  dailyRate       Decimal     @db.Decimal(12, 2)
  
  // Attendance summary
  eligibleWorkdays Int
  presentDays     Int
  absentDays      Int
  totalLateMinutes Int        @default(0)
  totalUndertimeMinutes Int   @default(0)
  totalOvertimeHours Decimal  @default(0) @db.Decimal(10, 5)
  
  // Earnings
  basicPay        Decimal     @db.Decimal(12, 2)
  overtimePay     Decimal     @default(0) @db.Decimal(12, 2)
  holidayPay      Decimal     @default(0) @db.Decimal(12, 2)
  cola            Decimal     @default(0) @db.Decimal(12, 2)
  kpi             Decimal     @default(0) @db.Decimal(12, 2)
  otherEarnings   Decimal     @default(0) @db.Decimal(12, 2)
  grossPay        Decimal     @db.Decimal(12, 2)
  
  // Deductions
  absenceDeduction    Decimal @default(0) @db.Decimal(12, 2)
  lateDeduction       Decimal @default(0) @db.Decimal(12, 2)
  undertimeDeduction  Decimal @default(0) @db.Decimal(12, 2)
  sssDeduction        Decimal @default(0) @db.Decimal(12, 2)
  philhealthDeduction Decimal @default(0) @db.Decimal(12, 2)
  pagibigDeduction    Decimal @default(0) @db.Decimal(12, 2)
  sssLoanDeduction    Decimal @default(0) @db.Decimal(12, 2)
  pagibigLoanDeduction Decimal @default(0) @db.Decimal(12, 2)
  otherLoanDeduction  Decimal @default(0) @db.Decimal(12, 2)
  cashAdvanceDeduction Decimal @default(0) @db.Decimal(12, 2)
  thirteenthMonthAdj  Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions     Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions     Decimal @db.Decimal(12, 2)
  
  // Net
  netPay          Decimal     @db.Decimal(12, 2)
  netPayInWords   String?
  
  // Government deductions applied flag
  govDeductionsApplied Boolean @default(false)
  
  // KPI voiding (based on monthly attendance)
  kpiVoided           Boolean @default(false)
  kpiVoidReason       String?
  monthlyLateCount    Int     @default(0)   // Total late occurrences for the month
  monthlyAbsentCount  Int     @default(0)   // Total absences for the month
  lateCount           Int     @default(0)   // Late occurrences in this cutoff
  absentCount         Int     @default(0)   // Absences in this cutoff
  
  // Computation breakdown JSON
  computationBreakdown Json?
  
  isMissing       Boolean     @default(false)  // Employee missing in import
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  earnings        PayslipEarning[]
  deductions      PayslipDeduction[]
  
  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

model PayslipEarning {
  id          String    @id @default(cuid())
  payslipId   String
  payslip     Payslip   @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type        String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  sortOrder   Int       @default(0)
  
  @@map("payslip_earnings")
}

model PayslipDeduction {
  id          String    @id @default(cuid())
  payslipId   String
  payslip     Payslip   @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type        String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  sortOrder   Int       @default(0)
  
  @@map("payslip_deductions")
}

// ==================== IMPORT HISTORY ====================

model ImportHistory {
  id              String      @id @default(cuid())
  payrollRunId    String
  payrollRun      PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  
  fileName        String
  fileData        Bytes?      // Store original file
  sheetName       String?
  columnMapping   Json        // Store the mapping used
  
  totalRows       Int
  successRows     Int
  errorRows       Int
  missingEmployees Json?
  unrecognizedEmployees Json?
  
  importedBy      String
  importedAt      DateTime    @default(now())
  
  @@map("import_history")
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  payrollRunId    String?
  payrollRun      PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)
  
  action          String      // KPI_EDIT, FINALIZE, OVERRIDE, etc.
  entityType      String      // Payslip, PayrollRun, Employee
  entityId        String
  
  oldValue        Json?
  newValue        Json?
  description     String?
  
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime    @default(now())
  
  @@index([entityType, entityId])
  @@index([payrollRunId])
  @@map("audit_logs")
}

// ==================== SETTINGS ====================

model Setting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String
  description String?
  updatedAt   DateTime  @updatedAt
  
  @@map("settings")
}

// ==================== HOLIDAYS ====================

enum HolidayType {
  REGULAR    // No work, 100% basic pay
  SPECIAL    // 30% of hours worked (max 8 hrs, OT excluded)
}

model Holiday {
  id          String      @id @default(cuid())
  name        String
  date        DateTime    @db.Date
  type        HolidayType
  year        Int
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@unique([date])
  @@index([year])
  @@map("holidays")
}
